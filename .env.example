# Firebase / Firestore project ID (also the Firebase Auth project).
FIRESTORE_PROJECT_ID=your-firebase-project-id

# Anthropic API key for Pydantic AI training-tip generation.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Path to the Firebase service-account JSON. LOCAL ONLY — on Cloud Run the
# attached service account is used and this must be left unset.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json

# Signs the NiceGUI session cookie AND the strain_auth cookie. If unset it
# falls back to an insecure dev default, so set a long random value. Use the
# SAME value locally and in prod or existing login cookies stop verifying.
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
STORAGE_SECRET=change-me-to-a-long-random-string

# Logging verbosity. DEBUG surfaces verify_id_token success + client auth
# breadcrumbs (auth.clientlog). Use DEBUG while debugging auth, INFO otherwise.
LOG_LEVEL=DEBUG
